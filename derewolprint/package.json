{
  "name": "derewolprint",
  "version": "1.0.0",
  "description": "DerewolPrint — Impression intelligente",
  "main": "main/main.js",
  "scripts": {
    "start": "cross-env NODE_ENV=development electron .",
    "prebuild": "node scripts/clean-dist.js",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "cross-env": "^7.0.3",
    "electron-log": "^5.0.0",
    "mammoth": "^1.7.0",
    "nodemailer": "^8.0.7",
    "pdf-to-printer": "^5.4.0",
    "pdfjs-dist": "^5.6.205",
    "qrcode": "^1.5.4",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.derewol.print",
    "productName": "DerewolPrint",
    "copyright": "Copyright © 2025 Derewol",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main/**/*",
      "preload/**/*",
      "renderer/**/*",
      "services/**/*",
      "!services/bluetooth.js",
      "!services/bluetoothSync.js",
      "node_modules/**/*",
      "package.json",
      "!**/*.map",
      "!**/test*",
      "!**/scripts/**",
      "!node_modules/.cache"
    ],
    "extraResources": [
      {
        "from": "config.json",
        "to": "config.json"
      },
      {
        "from": "node_modules/pdfjs-dist/build/pdf.min.mjs",
        "to": "../renderer/pdf.min.js"
      },
      {
        "from": "node_modules/pdfjs-dist/build/pdf.worker.min.mjs",
        "to": "../renderer/pdf.worker.min.js"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DerewolPrint",
      "language": "1036"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/pdf-to-printer/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
