# Derewol .gitignore
# Fichiers et dossiers à ne pas commiter

# ═══════════════════════════════════════════════════════════════
# Environment & Secrets
# ═══════════════════════════════════════════════════════════════
.env
.env.local
.env.*.local
.env.development
.env.production
config.json

# ═══════════════════════════════════════════════════════════════
# Bluetooth Local Data
# ═══════════════════════════════════════════════════════════════
.derewol/          # Dossier de réception et logs
~/.derewol/        # Sur le système de fichiers

# ═══════════════════════════════════════════════════════════════
# Node & NPM
# ═══════════════════════════════════════════════════════════════
node_modules/
npm-debug.log*
npm-cache/
package-lock.json  # Optionnel: selon votre workflow

# ═══════════════════════════════════════════════════════════════
# Build & Distribution
# ═══════════════════════════════════════════════════════════════
dist/
build/
out/
*.exe
*.zip
*.tar.gz

# ═══════════════════════════════════════════════════════════════
# IDE & Editors
# ═══════════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ═══════════════════════════════════════════════════════════════
# OS Specific
# ═══════════════════════════════════════════════════════════════
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ═══════════════════════════════════════════════════════════════
# Logs
# ═══════════════════════════════════════════════════════════════
logs/
*.log
pids/
*.pid
*.seed

# ═══════════════════════════════════════════════════════════════
# Electron Build
# ═══════════════════════════════════════════════════════════════
dist_electron/
release/

# ═══════════════════════════════════════════════════════════════
# OS-specific (Windows)
# ═══════════════════════════════════════════════════════════════
*.lnk
*.exe
*.msi

# ═══════════════════════════════════════════════════════════════
# Temporary Files
# ═══════════════════════════════════════════════════════════════
*.tmp
*.bak
*.swp
.temp/
temp/